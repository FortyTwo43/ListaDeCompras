{
  "expo": {
    "name": "listaDeCompras",
    "slug": "listaDeCompras",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "listadecompras",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#13131A",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.neysser.listadecompras"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ba47edb1-6763-4aa0-a6cc-11bc1694ce12"
      }
    }
  }
}
